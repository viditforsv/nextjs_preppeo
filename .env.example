# Copy to .env.local and fill in values
# Non-secret defaults (NEXT_PUBLIC_ENVIRONMENT, NEXT_PUBLIC_APP_URL) are
# already set in .env.development and .env.production — no need to duplicate here.

# Dev Supabase
NEXT_PUBLIC_SUPABASE_URL_DEV=https://YOUR_DEV_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY_DEV=your_dev_anon_key
SUPABASE_SERVICE_ROLE_KEY_DEV=your_dev_service_role_key

# Production Supabase
NEXT_PUBLIC_SUPABASE_URL_PROD=https://YOUR_PROD_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY_PROD=your_prod_anon_key
SUPABASE_SERVICE_ROLE_KEY_PROD=your_prod_service_role_key

# Fallback (points to DEV for safety — used by scripts that don't use env.ts)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_DEV_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_dev_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_dev_service_role_key

# Google Authentication
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Razorpay Live
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=your_live_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxx

# Razorpay Test
RAZORPAY_KEY_ID_TEST=rzp_test_xxx
RAZORPAY_KEY_SECRET_TEST=your_test_secret

# AI Keys
GOOGLE_GEMINI_API_KEY=your_gemini_key
OPENAI_API_KEY=your_openai_key

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.de.sentry.io/XXX
SENTRY_AUTH_TOKEN=your_sentry_auth_token  # for source map uploads during CI build

# Desmos
NEXT_PUBLIC_DESMOS_API_KEY=your_desmos_key

# SMTP (ZeptoMail)
SMTP_HOST=smtp.zeptomail.in
SMTP_PORT=465
SMTP_USER=emailapikey
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=noreply@preppeo.com
SMTP_FROM_NAME=Preppeo
