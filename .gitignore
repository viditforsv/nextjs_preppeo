# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Google service account keys
google-service-account-key.json
*service-account*.json
credentials.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — secrets stay in .env.local (never committed)
.env.local
.env.local.*
.env*.local
# .env.development and .env.production are committed (non-secret defaults only)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# dev templates (local reference only)
.backup/dev-templates/
scripts/node_modules/
__pycache__/
